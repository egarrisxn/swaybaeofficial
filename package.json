{
  "name": "swaybaeofficial",
  "version": "1.0.0",
  "description": "The official site for content creator Sway Bae.",
  "homepage": "https://swaybae.net",
  "author": "Ethan G. (https://egxworld.net/)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/egarrisxn/swaybaeofficial"
  },
  "keywords": [
    "sanity",
    "nextjs",
    "react",
    "tailwindcss",
    "vercel"
  ],
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --check --ignore-path .gitignore .",
    "format:fix": "prettier --write --ignore-path .gitignore .",
    "analyze": "cross-env ANALYZE=true pnpm run build"
  },
  "dependencies": {
    "@next/bundle-analyzer": "14.2.3",
    "@sanity/image-url": "^1.0.2",
    "@sanity/preview-url-secret": "^1.6.17",
    "@sanity/react-loader": "^1.10.1",
    "@vercel/analytics": "^1.3.1",
    "@vercel/speed-insights": "^1.0.11",
    "embla-carousel-class-names": "^8.1.3",
    "embla-carousel-react": "^8.1.3",
    "next": "14.2.3",
    "next-sanity": "^9.3.10",
    "next-themes": "^0.3.0",
    "nodemailer": "^6.9.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "sharp": "^0.33.4",
    "use-debounce": "^10.0.1"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/typography": "^0.5.13",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.3",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tailwindcss": "^3.4.3"
  },
  "prettier": {
    "semi": false,
    "tabWidth": 2,
    "printWidth": 100,
    "bracketSpacing": false,
    "singleQuote": true,
    "jsxSingleQuote": true,
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "packageManager": "pnpm@9.1.3+sha512.7c2ea089e1a6af306409c4fc8c4f0897bdac32b772016196c469d9428f1fe2d5a21daf8ad6512762654ac645b5d9136bb210ec9a00afa8dbc4677843ba362ecd"
